import { AppStatus } from "../app-status.slint";
import { Slider } from "std-widgets.slint";
import { MarginBox } from "margin-box.slint";
import { HorizontalDivider } from "divider.slint";
import { Palette } from "../palette.slint";
import { IconFontFilled } from "../assets/icon/iconfont.slint";
import { SongDetail } from "../types/types.slint";


export global PlayerProperty {
    // 当前播放中的歌曲信息，由外部状态驱动。
    in property <SongDetail> playing-song;

    // 播放状态机：none/pause/playing/loading。
    in-out property <int> status-tragger: 1;
    out property <int> status-none: 0;
    out property <int> status-pause: 1;
    out property <int> status-playing: 2;
    out property <int> status-loading: 3;

    // 播放模式状态。
    in-out property <bool> shuffled: false;
    in-out property <int> loop-type: 0;

    // 文本时间与整型毫秒值并存：前者展示，后者用于 Slider 计算。
    in-out property <string> played-duration: "0:00:00";
    in-out property <string> total-duraiton: "0:00:00";
    
    in-out property <int> played-duration-int: 0;
    in-out property <int> total-duration-int: 1;

    // 对外事件回调，由 Rust 侧绑定具体行为。
    callback next();
    callback prev();
    callback pause-resume();
    callback seek-to-duration(int);
    callback event-loop();
    callback toggle-shuffle();
    callback toggle-repeat();

    in-out property <duration> event-loop-gap: 100ms;
}


component PauseButton inherits Rectangle {
    in property <color> common-background;
    Rectangle {
        // 悬停时切换渐变和内层背景，突出主按钮可点击状态。
        states [
            hover when pause.has-hover :{
                background: @linear-gradient(
                    135deg,
                    #006EBE 0%,
                    #1C5DAF 25%,
                    #384E9E 50%,
                    #543E8E 75%,
                    #703080 100%
                );
                pause-container.background: Palette.neutral-lighter-alt;
            }
            common when !pause.has-hover :{
                background: @linear-gradient(
                    135deg,
                    #0078D4 0%,
                    #2068C2 25%,
                    #4058B0 50%,
                    #6048A0 75%,
                    #803890 100% 
                );
                pause-container.background: common-background.with-alpha(1);
            }
        ]

        width: 52px;
        height: 52px;
        border-radius: 26px;

        pause-container := Rectangle {
            border-radius: 22px;
            width: parent.width - 8px;
            height: parent.height - 8px;
            
            background: root.background;

            pause := TouchArea {
                // 按当前播放状态切换图标：播放(三角) / 暂停(双竖线)。
                IconFontFilled {
                    vertical-alignment: center;
                    text:  PlayerProperty.status-tragger == PlayerProperty.status-none 
                        || PlayerProperty.status-tragger == PlayerProperty.status-pause? "\u{f611}" : "\u{e8e0}";
                    font-size: 28px;
                }

                clicked => {
                    PlayerProperty.pause-resume();
                }
            }
        }
    }
}

component CommonButton inherits Rectangle{
    in property <string> iconfont;
    
    callback clicked();

    ta := TouchArea {
        clicked => { root.clicked() }
    }

    width: 35px;
    height: 35px;
    border-radius: 4px;
    IconFontFilled {
        text: iconfont;
        font-size: 20px;
    }

    states [
        hover when ta.has-hover : {
            background: Palette.neutral-light;
        }
    ]

}

export component Player inherits Rectangle {
    // 播放器底栏：上方进度区 + 下方详情/控制区。
    background: white;

    Timer {
        // 周期触发：推进播放状态并同步进度条（非用户拖拽时）。
        interval: PlayerProperty.event-loop-gap;
        running: true;
        triggered => {
            PlayerProperty.event-loop();
            slider.update-slider();
        }
    }

    height: 111px;
    HorizontalDivider {
        y: 0px;
    }

    VerticalLayout {
        y: 1px;
        height: 110px;
        HorizontalLayout {
            height: 30px;
            padding-left: 10px;
            padding-right: 10px;
            Text {
                text: PlayerProperty.played-duration;
                vertical-alignment: center;
            }

            MarginBox {
                horizontal-stretch: 1;
                margin-horizontal: 15px;

                slider := Slider {
                    // 使用毫秒整数，避免浮点误差导致的跳动。
                    minimum: 0;
                    maximum: PlayerProperty.total-duration-int;
                    value: 0;
                    width: 100%;
                    step: 10 * 1000;
                    property <int> current-duration;
                    property <bool> user-inputing;

                    released(position) => {
                        // 用户释放滑块时才提交 seek，减少频繁跳播。
                        PlayerProperty.seek-to-duration(position);
                        user-inputing = false;
                    }

                    changed(value) => {
                        // 拖动期间暂停自动同步，防止“抢焦点”回弹。
                        user-inputing = true;
                    }
                    
                    
                    function update-slider() {
                        if !user-inputing {
                            self.value = PlayerProperty.played-duration-int;
                        }
                    }
                }
            }
            
            Text {
                text: PlayerProperty.total-duraiton;
                vertical-alignment: center;
            }
        }
    
        MarginBox {
            margin-horizontal: 5px;
            margin-buttom: 5px;
            // 左侧：封面 + 曲目信息。
            detail := Rectangle {
                x: 0;
                width: (parent.width - control.width) / 2;
                ta_detail := TouchArea {
                    
                }
                // 封面区域。
                HorizontalLayout {
                    alignment: start;
                    spacing: 10px;

                    Rectangle {
                        height: 100%;
                        width:  self.height - 10px + 5px;
                        picture := Rectangle {
                            x: 5px;
                            border-width: 1px;
                            border-color: Palette.neutral-quaternary;
                            clip: true;
                            border-radius: 4px;
                            width: parent.width - 5px;
                            height: self.width;
                            Image {
                                width: 100%;
                                height: 100%;
                                source: PlayerProperty.playing-song.image;
                            }
                        }
                    }


                    VerticalLayout {
                        spacing: 0px;
                        // 歌曲名（主信息）。
                        Text {
                            vertical-alignment: center;
                            text: PlayerProperty.playing-song.name;
                            color: Palette.neutral-primary;
                            font-size: 20px;
                            font-weight: 400;
                            overflow: elide;
                            font-family: "Microsoft YaHei";
                        }
                        // 歌手（次信息，空值时不渲染）。
                        if !PlayerProperty.playing-song.singer.is-empty : Text {
                            vertical-alignment: top;
                            text:  "\u{2022} " + PlayerProperty.playing-song.singer;
                            color: Palette.neutral-secondary;
                            overflow: elide;
                            font-size: 14px;    
                        }
                    }
                }
                horizontal-stretch: 1;
                border-radius: 6px;
                states [
                    hover when ta_detail.has-hover :{
                        background: Palette.neutral-light;
                    }
                ]
            }

            control := Rectangle {
                x: detail.width;
                width: 240px;

                Rectangle {
                    height: 56px;
                    HorizontalLayout {
                    spacing: 5px;
                    
                    Rectangle {
                        horizontal-stretch: 1;
                        CommonButton {
                            // 循环模式图标：0=不循环,1=单曲循环,2=列表循环。
                            iconfont: {
                                if PlayerProperty.loop-type == 0 {
                                    "\u{f175}" // no repeat
                                } else if PlayerProperty.loop-type == 1 {
                                    "\u{ef34}" // 1 repeat
                                } else  { 
                                    "\u{f172}"// repeat all
                                }
                            }
                            clicked => {
                                PlayerProperty.toggle-repeat();
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        CommonButton {
                            iconfont: "\u{e9d2}";
                            clicked => {
                                PlayerProperty.prev();
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 2;
                        PauseButton {
                            common-background: root.background;
                        }
                    }
                    
                    Rectangle {
                        horizontal-stretch: 1;
                        CommonButton {
                            iconfont: "\u{e876}";
                            clicked => {
                                PlayerProperty.next();
                            }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        CommonButton {
                            // 随机播放开关图标。
                            iconfont: PlayerProperty.shuffled ? "\u{ef39}" : "\u{ef3f}";
                            clicked => {
                                PlayerProperty.toggle-shuffle();
                            }
                        }
                    }
                }
                }

            }

            more := Rectangle {
                // 右侧占位区：与左侧详情区平衡，确保控制区居中。
                width: (parent.width - control.width) / 2;
                x: parent.width - self.width;
                horizontal-stretch: 1;
            }
        }
    }
}
